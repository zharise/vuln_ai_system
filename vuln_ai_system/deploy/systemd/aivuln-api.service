[Unit]
Description=AI Vulnerability Mining API
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/aivuln
Environment=PYTHONPATH=/opt/aivuln/src
ExecStart=/opt/aivuln/.venv/bin/uvicorn aivuln.api:app --host 0.0.0.0 --port 18080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

